{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "WmScript",
  "scopeName": "source.wmscript",
  "patterns": [
    { "include": "#annotations" },
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#invoke" },
    { "include": "#builtins" },
    { "include": "#log" },
    { "include": "#strings" },
    { "include": "#template-strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#service-ref" },
    { "include": "#constants" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "annotations": {
      "patterns": [
        {
          "match": "(//\\s*)(@(?:input|output))\\s+(\\w+)(?:\\s*:\\s*(\\S+))?",
          "captures": {
            "1": { "name": "comment.line.double-slash.wmscript" },
            "2": { "name": "keyword.other.annotation.wmscript" },
            "3": { "name": "variable.parameter.wmscript" },
            "4": { "name": "support.type.wmscript" }
          }
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.wmscript",
          "match": "//.*$"
        },
        {
          "name": "comment.line.hash.wmscript",
          "match": "#.*$"
        },
        {
          "name": "comment.block.wmscript",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.wmscript",
          "match": "\\b(if|elif|else|for|in|while|try|catch|end|return|raise|break|continue|skip)\\b"
        },
        {
          "name": "keyword.other.invoke.wmscript",
          "match": "\\binvoke\\b"
        }
      ]
    },
    "invoke": {
      "patterns": [
        {
          "match": "\\b(invoke)\\s+([a-zA-Z_][a-zA-Z0-9_.]*:[a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.invoke.wmscript" },
            "2": { "name": "entity.name.function.service-ref.wmscript" }
          }
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.wmscript",
          "match": "\\b(num|str|int|date|len|sum|min|max|join|split|keys|values|exists|typeof)\\b(?=\\s*\\()"
        }
      ]
    },
    "log": {
      "patterns": [
        {
          "match": "\\b(log)\\.(error|warn|info|debug)\\b",
          "captures": {
            "1": { "name": "support.class.log.wmscript" },
            "2": { "name": "support.function.log-level.wmscript" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.wmscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.wmscript",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.wmscript",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.wmscript",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "template-strings": {
      "patterns": [
        {
          "name": "string.interpolated.wmscript",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.wmscript",
              "match": "\\\\."
            },
            {
              "name": "meta.template-expression.wmscript",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.wmscript" } },
              "endCaptures": { "0": { "name": "punctuation.definition.template-expression.end.wmscript" } },
              "patterns": [
                { "include": "#identifiers" },
                { "include": "#operators" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.wmscript",
          "match": "\\b-?\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.wmscript",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.wmscript",
          "match": "\\b(and|or|not)\\b|&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.null-coalesce.wmscript",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.null-safe.wmscript",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.arithmetic.wmscript",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.wmscript",
          "match": "(?<![=!<>])=(?!=)"
        }
      ]
    },
    "service-ref": {
      "patterns": [
        {
          "name": "entity.name.function.service-ref.wmscript",
          "match": "[a-zA-Z_][a-zA-Z0-9_.]*:[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.wmscript",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*:",
          "captures": {
            "1": { "name": "variable.parameter.wmscript" }
          }
        },
        {
          "name": "variable.other.wmscript",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
